{
  "name": "@taskflow/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--import=../../scripts/load-env.mjs next dev --port 3001",
    "build": "cross-env NODE_OPTIONS=--import=../../scripts/load-env.mjs next build",
    "start": "cross-env NODE_OPTIONS=--import=../../scripts/load-env.mjs next start --port 3001",
    "lint": "eslint src/ app/",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "cross-env NODE_OPTIONS=--import=../../scripts/load-env.mjs vitest run --config vitest.integration.config.ts",
    "clean": "rm -rf .next .turbo node_modules"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "@taskflow/db": "workspace:*",
    "@taskflow/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "jose": "^6.0.0",
    "next": "^15.1.0",
    "pino": "^9.5.0",
    "redis": "^5.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.17.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "msw": "^2.7.0",
    "testcontainers": "^10.17.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
